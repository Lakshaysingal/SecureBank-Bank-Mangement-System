<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Transactions - Admin</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <%- include('partials/admin-navbar') %>
    
    <div class="admin-container">
        <h1>📝 All Transactions</h1>
        
        <div class="admin-table">
            <table>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>User</th>
                        <th>Account</th>
                        <th>Type</th>
                        <th>Amount</th>
                        <th>Description</th>
                    </tr>
                </thead>
                <tbody>
                    <% transactions.forEach(trans => { %>
                        <tr>
                            <td><%= new Date(trans.date).toLocaleString() %></td>
                            <td><%= trans.userName %></td>
                            <td><%= trans.accountNumber %></td>
                            <td><%= trans.type.toUpperCase() %></td>
                            <td class="<%= ['deposit', 'loan', 'received'].includes(trans.type) ? 'credit' : 'debit' %>">
                                <%= ['deposit', 'loan', 'received'].includes(trans.type) ? '+' : '-' %>₹<%= trans.amount.toFixed(2) %>
                            </td>
                            <td><%= trans.description %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>
