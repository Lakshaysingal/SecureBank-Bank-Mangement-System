<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bill Payment - SecureBank</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/navbar', { user: user }) %>
    
    <div class="form-container">
        <div class="form-card">
            <h2>📱 Pay Bills</h2>
            <p class="balance-info">Available Balance: ₹<%= user.balance.toFixed(2) %></p>
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="error"><%= error %></div>
            <% } %>
            <form action="/bank/bill-payment" method="POST" id="billForm">
                <div class="form-group">
                    <label>Bill Type</label>
                    <select name="billType" required>
                        <option value="Electricity">Electricity</option>
                        <option value="Water">Water</option>
                        <option value="Gas">Gas</option>
                        <option value="Mobile">Mobile</option>
                        <option value="Internet">Internet</option>
                        <option value="DTH">DTH</option>
                        <option value="Insurance">Insurance</option>
                        <option value="Credit Card">Credit Card Bill</option>
                        <option value="Education">Education</option>
                        <option value="Shopping">Shopping</option>
                        <option value="Food">Food</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Bill Number</label>
                    <input type="text" name="billNumber" required>
                </div>
                <div class="form-group">
                    <label>Amount (₹)</label>
                    <input type="number" name="amount" id="billAmount" step="0.01" min="1" required>
                </div>
                
                <div class="form-group">
                    <label>Payment Method</label>
                    <select name="paymentMethod" id="paymentMethod" required onchange="toggleCardSelection()">
                        <option value="balance">Account Balance</option>
                        <option value="card">Pay with Card</option>
                    </select>
                </div>

                <div class="form-group" id="cardSelection" style="display: none;">
                    <label>Select Card</label>
                    <select name="cardId" id="cardId">
                        <option value="">-- Select a Card --</option>
                        <% if (user.cards && user.cards.length > 0) { %>
                            <% user.cards.filter(card => card.isActive).forEach(card => { %>
                                <option value="<%= card._id %>" data-type="<%= card.cardType %>" data-limit="<%= card.availableCredit %>">
                                    <%= card.cardType.toUpperCase() %> - **** <%= card.cardNumber.slice(-4) %>
                                    <% if (card.cardType === 'credit') { %>
                                        (Available: ₹<%= card.availableCredit.toFixed(2) %>)
                                    <% } %>
                                </option>
                            <% }) %>
                        <% } %>
                    </select>
                    <small class="card-info" id="cardInfo"></small>
                </div>

                <div class="payment-summary" id="paymentSummary" style="display: none;">
                    <h4>Payment Summary</h4>
                    <div class="summary-item">
                        <span>Payment Method:</span>
                        <span id="summaryMethod">Account Balance</span>
                    </div>
                    <div class="summary-item">
                        <span>Amount to Pay:</span>
                        <span id="summaryAmount">₹0.00</span>
                    </div>
                </div>

                <button type="submit" class="btn-primary">Pay Now</button>
                <a href="/bank/dashboard" class="btn-secondary">Cancel</a>
            </form>
        </div>
    </div>

    <script>
        function toggleCardSelection() {
            const paymentMethod = document.getElementById('paymentMethod').value;
            const cardSelection = document.getElementById('cardSelection');
            const paymentSummary = document.getElementById('paymentSummary');
            
            if (paymentMethod === 'card') {
                cardSelection.style.display = 'block';
                paymentSummary.style.display = 'block';
            } else {
                cardSelection.style.display = 'none';
                document.getElementById('summaryMethod').textContent = 'Account Balance';
            }
            updateSummary();
        }

        function updateSummary() {
            const amount = document.getElementById('billAmount').value;
            const paymentMethod = document.getElementById('paymentMethod').value;
            const cardSelect = document.getElementById('cardId');
            const selectedCard = cardSelect.options[cardSelect.selectedIndex];
            
            document.getElementById('summaryAmount').textContent = `₹${parseFloat(amount || 0).toFixed(2)}`;
            
            if (paymentMethod === 'card' && selectedCard.value) {
                const cardType = selectedCard.getAttribute('data-type');
                const cardNumber = selectedCard.text.split('-')[1].trim();
                document.getElementById('summaryMethod').textContent = `${cardType.toUpperCase()} Card - ${cardNumber}`;
                
                if (cardType === 'credit') {
                    const availableLimit = parseFloat(selectedCard.getAttribute('data-limit'));
                    document.getElementById('cardInfo').textContent = `Available Credit: ₹${availableLimit.toFixed(2)}`;
                    document.getElementById('cardInfo').style.color = availableLimit >= parseFloat(amount || 0) ? '#10b981' : '#ef4444';
                } else {
                    document.getElementById('cardInfo').textContent = 'Amount will be deducted from account balance';
                    document.getElementById('cardInfo').style.color = '#666';
                }
            }
        }

        document.getElementById('billAmount').addEventListener('input', updateSummary);
        document.getElementById('cardId').addEventListener('change', updateSummary);
        
        document.getElementById('billForm').addEventListener('submit', function(e) {
            const paymentMethod = document.getElementById('paymentMethod').value;
            if (paymentMethod === 'card') {
                const cardId = document.getElementById('cardId').value;
                if (!cardId) {
                    e.preventDefault();
                    alert('Please select a card for payment');
                }
            }
        });
    </script>
</body>
</html>
