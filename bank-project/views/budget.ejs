<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Budget Tracking - SecureBank</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <%- include('partials/navbar', { user: user }) %>
    
    <div class="dashboard-container">
        <div class="page-header">
            <h2>💰 Budget Tracking</h2>
            <button class="btn-primary" onclick="showBudgetModal()">+ Set Budget</button>
        </div>

        <div class="budget-overview">
            <h3>Current Month: <%= new Date().toLocaleString('default', { month: 'long', year: 'numeric' }) %></h3>
        </div>

        <div class="budget-grid">
            <% 
            const categories = ['food', 'shopping', 'entertainment', 'transport', 'bills', 'health', 'education', 'other'];
            categories.forEach(category => {
                const budget = user.budgets.find(b => b.category === category && b.month === currentMonth);
                const spent = spending[category] || 0;
                const limit = budget ? budget.limit : 0;
                const percentage = limit > 0 ? (spent / limit * 100) : 0;
                const status = percentage > 100 ? 'over' : percentage > 80 ? 'warning' : 'good';
            %>
                <div class="budget-card <%= status %>">
                    <div class="budget-icon"><%= category === 'food' ? '🍔' : category === 'shopping' ? '🛍️' : category === 'entertainment' ? '🎬' : category === 'transport' ? '🚗' : category === 'bills' ? '📱' : category === 'health' ? '💊' : category === 'education' ? '📚' : '📦' %></div>
                    <h4><%= category.charAt(0).toUpperCase() + category.slice(1) %></h4>
                    <div class="budget-bar">
                        <div class="budget-progress" style="width: <%= Math.min(percentage, 100) %>%"></div>
                    </div>
                    <div class="budget-amounts">
                        <span>₹<%= spent.toFixed(2) %></span>
                        <span>/ ₹<%= limit.toFixed(2) %></span>
                    </div>
                    <p class="budget-status">
                        <% if (percentage > 100) { %>
                            ⚠️ Over budget by ₹<%= (spent - limit).toFixed(2) %>
                        <% } else if (percentage > 80) { %>
                            ⚡ <%= (100 - percentage).toFixed(0) %>% remaining
                        <% } else if (limit > 0) { %>
                            ✅ On track
                        <% } else { %>
                            ➕ No budget set
                        <% } %>
                    </p>
                    <% if (budget) { %>
                        <form action="/bank/budget/delete/<%= budget._id %>" method="POST" style="margin-top: 0.5rem;">
                            <button type="submit" class="btn-secondary-small" onclick="return confirm('Delete this budget?')">Remove</button>
                        </form>
                    <% } %>
                </div>
            <% }) %>
        </div>

        <div class="spending-chart-container">
            <h3>Spending by Category</h3>
            <div class="chart-wrapper">
                <canvas id="spendingChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Set Budget Modal -->
    <div id="budgetModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeBudgetModal()">&times;</span>
            <h3>Set Category Budget</h3>
            <form action="/bank/budget/create" method="POST">
                <div class="form-group">
                    <label>Category</label>
                    <select name="category" required>
                        <option value="food">🍔 Food & Dining</option>
                        <option value="shopping">🛍️ Shopping</option>
                        <option value="entertainment">🎬 Entertainment</option>
                        <option value="transport">🚗 Transport</option>
                        <option value="bills">📱 Bills & Utilities</option>
                        <option value="health">💊 Health & Fitness</option>
                        <option value="education">📚 Education</option>
                        <option value="other">📦 Other</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Monthly Limit (₹)</label>
                    <input type="number" name="limit" min="100" step="100" required>
                </div>
                <button type="submit" class="btn-primary full-width">Set Budget</button>
            </form>
        </div>
    </div>

    <script>
        function showBudgetModal() {
            document.getElementById('budgetModal').style.display = 'block';
        }
        function closeBudgetModal() {
            document.getElementById('budgetModal').style.display = 'none';
        }
        
        const spending = <%- JSON.stringify(spending) %>;
        
        new Chart(document.getElementById('spendingChart'), {
            type: 'doughnut',
            data: {
                labels: Object.keys(spending).map(k => k.charAt(0).toUpperCase() + k.slice(1)),
                datasets: [{
                    data: Object.values(spending),
                    backgroundColor: ['#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0', '#9966FF', '#FF9F40', '#FF6384', '#C9CBCF']
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                aspectRatio: 2,
                plugins: {
                    legend: { 
                        position: 'bottom',
                        labels: {
                            boxWidth: 15,
                            padding: 10,
                            font: { size: 11 }
                        }
                    }
                }
            }
        });
        
        window.onclick = function(event) {
            const modal = document.getElementById('budgetModal');
            if (event.target == modal) modal.style.display = 'none';
        }
    </script>
</body>
</html>
