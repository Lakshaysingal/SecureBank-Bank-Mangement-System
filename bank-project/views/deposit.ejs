<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Deposit - SecureBank</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/navbar', { user: user }) %>
    
    <div class="form-container">
        <div class="form-card">
            <h2>💰 Deposit Money</h2>
            <p class="balance-info">Current Balance: ₹<%= user.balance.toFixed(2) %></p>
            <form action="/bank/deposit" method="POST">
                <div class="form-group">
                    <label>Amount</label>
                    <input type="number" name="amount" step="0.01" min="1" required>
                </div>
                <button type="submit" class="btn-primary">Deposit</button>
                <a href="/bank/dashboard" class="btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</body>
</html>
