<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SecureBank - Your Trusted Banking Partner</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="landing-page">
    <nav class="navbar">
        <div class="container">
            <div class="logo">💎 SecureBank</div>
            <div class="nav-links">
                <a href="/auth/login" class="btn-secondary">Login</a>
                <a href="/auth/register" class="btn-primary">Open Account</a>
            </div>
        </div>
    </nav>

    <section class="hero">
        <div class="container">
            <h1>Welcome to Modern Banking</h1>
            <p>Experience seamless banking with advanced features and complete security</p>
            <div class="hero-buttons">
                <a href="/auth/register" class="btn-large">Get Started</a>
                <a href="/auth/login" class="btn-outline">Sign In</a>
            </div>
        </div>
    </section>

    <section class="features">
        <div class="container">
            <h2>Our Services</h2>
            <div class="feature-grid">
                <div class="feature-card">
                    <div class="icon">💰</div>
                    <h3>Deposit & Withdraw</h3>
                    <p>Easy cash deposits and withdrawals anytime</p>
                </div>
                <div class="feature-card">
                    <div class="icon">🔄</div>
                    <h3>Money Transfer</h3>
                    <p>Instant transfers to any account</p>
                </div>
                <div class="feature-card">
                    <div class="icon">💳</div>
                    <h3>Loans</h3>
                    <p>Quick approval personal loans</p>
                </div>
                <div class="feature-card">
                    <div class="icon">📈</div>
                    <h3>Fixed Deposits</h3>
                    <p>High interest rates on FDs</p>
                </div>
                <div class="feature-card">
                    <div class="icon">📱</div>
                    <h3>Bill Payments</h3>
                    <p>Pay all your bills in one place</p>
                </div>
                <div class="feature-card">
                    <div class="icon">📊</div>
                    <h3>Analytics</h3>
                    <p>Track your expenses and income</p>
                </div>
            </div>
        </div>
    </section>

    <footer>
        <p>&copy; 2024 SecureBank. All rights reserved.</p>
    </footer>
</body>
</html>
