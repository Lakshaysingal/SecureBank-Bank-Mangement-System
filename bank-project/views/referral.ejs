<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Referral Program - SecureBank</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/navbar', { user: user }) %>
    
    <div class="dashboard-container">
        <div class="referral-header">
            <h2>🎁 Refer & Earn</h2>
            <p>Invite friends and earn ₹500 for each successful referral!</p>
        </div>

        <div class="referral-code-section">
            <div class="code-card">
                <h3>Your Referral Code</h3>
                <div class="referral-code">
                    <input type="text" value="<%= user.referralCode %>" id="refCode" readonly>
                    <button class="btn-primary" onclick="copyCode()">📋 Copy</button>
                </div>
                <p class="share-text">Share this code with your friends</p>
            </div>

            <div class="referral-link-card">
                <h3>Referral Link</h3>
                <div class="referral-link">
                    <input type="text" value="http://localhost:3000/auth/register?ref=<%= user.referralCode %>" id="refLink" readonly>
                    <button class="btn-primary" onclick="copyLink()">📋 Copy Link</button>
                </div>
            </div>
        </div>

        <div class="referral-stats">
            <div class="stat-card">
                <div class="stat-icon">👥</div>
                <div>
                    <h4>Total Referrals</h4>
                    <p class="stat-number"><%= user.referralCount || 0 %></p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">🎁</div>
                <div>
                    <h4>Reward Points</h4>
                    <p class="stat-number"><%= user.rewardPoints || 0 %></p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">💰</div>
                <div>
                    <h4>Earnings</h4>
                    <p class="stat-number">₹<%= ((user.referralCount || 0) * 500).toFixed(2) %></p>
                </div>
            </div>
        </div>

        <div class="how-it-works">
            <h3>How It Works</h3>
            <div class="steps-grid">
                <div class="step-card">
                    <div class="step-number">1</div>
                    <h4>Share Code</h4>
                    <p>Share your unique referral code with friends</p>
                </div>
                <div class="step-card">
                    <div class="step-number">2</div>
                    <h4>They Sign Up</h4>
                    <p>Friend registers using your code</p>
                </div>
                <div class="step-card">
                    <div class="step-number">3</div>
                    <h4>Get Rewarded</h4>
                    <p>Earn ₹500 after their first transaction</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        function copyCode() {
            const code = document.getElementById('refCode');
            code.select();
            document.execCommand('copy');
            alert('Referral code copied!');
        }
        
        function copyLink() {
            const link = document.getElementById('refLink');
            link.select();
            document.execCommand('copy');
            alert('Referral link copied!');
        }
    </script>
</body>
</html>
