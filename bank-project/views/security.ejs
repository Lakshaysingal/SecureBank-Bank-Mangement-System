<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Security Settings - SecureBank</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/navbar', { user: user }) %>
    
    <div class="dashboard-container">
        <h2>🔒 Security Settings</h2>
        
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="error"><%= error %></div>
        <% } %>

        <div class="security-grid">
            <!-- Two-Factor Authentication -->
            <div class="security-card">
                <h3>🔐 Two-Factor Authentication</h3>
                <p>Add an extra layer of security to your account</p>
                <% if (user.twoFactorEnabled) { %>
                    <p class="status-enabled">✅ Enabled</p>
                <% } else { %>
                    <p class="status-disabled">❌ Disabled</p>
                    <form action="/bank/security/enable-2fa" method="POST">
                        <button type="submit" class="btn-primary">Enable 2FA</button>
                    </form>
                <% } %>
                
                <% if (qrCode) { %>
                    <div class="qr-setup">
                        <p>Scan this QR code with your authenticator app:</p>
                        <img src="<%= qrCode %>" alt="2FA QR Code" style="max-width: 200px;">
                        <form action="/bank/security/verify-2fa" method="POST">
                            <div class="form-group">
                                <label>Enter 6-digit code:</label>
                                <input type="text" name="token" maxlength="6" required>
                            </div>
                            <button type="submit" class="btn-primary">Verify & Enable</button>
                        </form>
                    </div>
                <% } %>
            </div>

            <!-- Transaction PIN -->
            <div class="security-card">
                <h3>🔢 Transaction PIN</h3>
                <p>Set a 4-digit PIN for secure transactions</p>
                <% if (user.transactionPin) { %>
                    <p class="status-enabled">✅ PIN Set</p>
                <% } else { %>
                    <p class="status-disabled">❌ No PIN</p>
                <% } %>
                <button class="btn-primary" onclick="showPinModal()">
                    <%= user.transactionPin ? 'Change PIN' : 'Set PIN' %>
                </button>
            </div>

            <!-- Login History -->
            <div class="security-card">
                <h3>📱 Login History</h3>
                <p>View recent account access</p>
                <% if (user.loginHistory && user.loginHistory.length > 0) { %>
                    <div class="login-history">
                        <% user.loginHistory.slice(-5).reverse().forEach(login => { %>
                            <div class="login-item">
                                <p><strong><%= new Date(login.date).toLocaleString() %></strong></p>
                                <p><%= login.device || 'Unknown Device' %></p>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <p>No login history available</p>
                <% } %>
            </div>

            <!-- Account Status -->
            <div class="security-card">
                <h3>🛡️ Account Status</h3>
                <div class="status-info">
                    <p><strong>Status:</strong> <%= user.accountLocked ? '🔒 Locked' : '✅ Active' %></p>
                    <p><strong>Failed Login Attempts:</strong> <%= user.loginAttempts || 0 %></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Set PIN Modal -->
    <div id="pinModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closePinModal()">&times;</span>
            <h3>Set Transaction PIN</h3>
            <form action="/bank/security/set-pin" method="POST">
                <div class="form-group">
                    <label>Enter 4-digit PIN</label>
                    <input type="password" name="pin" maxlength="4" pattern="\d{4}" required>
                </div>
                <button type="submit" class="btn-primary full-width">Set PIN</button>
            </form>
        </div>
    </div>

    <script>
        function showPinModal() {
            document.getElementById('pinModal').style.display = 'block';
        }
        function closePinModal() {
            document.getElementById('pinModal').style.display = 'none';
        }
        window.onclick = function(event) {
            const modal = document.getElementById('pinModal');
            if (event.target == modal) modal.style.display = 'none';
        }
    </script>

    <style>
        .security-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 2rem;
            margin-top: 2rem;
        }
        .security-card {
            background: white;
            padding: 2rem;
            border-radius: 15px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        }
        .security-card h3 {
            margin-bottom: 1rem;
            color: #333;
        }
        .security-card p {
            color: #666;
            margin-bottom: 1rem;
        }
        .status-enabled {
            color: #10b981;
            font-weight: 600;
        }
        .status-disabled {
            color: #ef4444;
            font-weight: 600;
        }
        .qr-setup {
            margin-top: 1.5rem;
            text-align: center;
        }
        .login-history {
            margin-top: 1rem;
        }
        .login-item {
            padding: 0.75rem;
            background: #f9fafb;
            border-radius: 8px;
            margin-bottom: 0.5rem;
        }
        .login-item p {
            margin: 0.25rem 0;
            font-size: 0.9rem;
        }
        .status-info {
            margin-top: 1rem;
        }
    </style>
</body>
</html>
