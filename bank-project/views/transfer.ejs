<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Transfer - SecureBank</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/navbar', { user: user }) %>
    
    <div class="form-container">
        <div class="form-card">
            <h2>🔄 Transfer Money</h2>
            <p class="balance-info">Available Balance: ₹<%= user.balance.toFixed(2) %></p>
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="error"><%= error %></div>
            <% } %>
            <form action="/bank/transfer" method="POST">
                <div class="form-group">
                    <label>Recipient Account Number</label>
                    <input type="text" name="accountNumber" required>
                </div>
                <div class="form-group">
                    <label>Amount</label>
                    <input type="number" name="amount" step="0.01" min="1" max="<%= user.balance %>" required>
                </div>
                <button type="submit" class="btn-primary">Transfer</button>
                <a href="/bank/dashboard" class="btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</body>
</html>
